# ============================================================
# CopyTrade Engine — Environment Variables
# Copy this file to .env.local for local dev, and add the same
# keys to Vercel Project Settings → Environment Variables for prod.
# ============================================================

# --- Database (free tier: Neon, Supabase, or Railway Postgres) ---
DATABASE_URL="postgresql://user:password@host:5432/copytrade?sslmode=require"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# --- Google OAuth (https://console.cloud.google.com/apis/credentials) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Credential encryption (for exchange API keys at rest) ---
# Generate with: openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY=""

# --- Exchange API base URLs (mock-swappable; see src/lib/exchange) ---
BINANCE_API_BASE="https://fapi.binance.com"
BYBIT_API_BASE="https://api.bybit.com"

# --- Notifications (Stage 3 — leave blank until implemented) ---
TELEGRAM_BOT_TOKEN=""
DISCORD_WEBHOOK_URL=""
RESEND_API_KEY=""

# --- Admin bootstrap (first admin account; promote via seed script) ---
ADMIN_BOOTSTRAP_EMAIL=""

# --- Vercel Cron protection ---
# Generate with: openssl rand -hex 32
CRON_SECRET=""
